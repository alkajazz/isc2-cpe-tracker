# Live data — never commit the CSV or any user data
cissp-cpe-tracker/data/

# Environment / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temp files written by storage.py during atomic CSV writes
*.tmp

# Claude Code project instructions — contains deployment credentials
CLAUDE.md

# Claude Code config — never commit
.claude/

# Loose screenshots at repo root (not documentation)
*.png
*.jpg
*.jpeg

# Screenshots — only doc screenshots (referenced in README) are committed
# Allowlist the specific files used in documentation:
screenshots/*
!screenshots/dashboard.png
!screenshots/vendor-cpe-mode.gif
!screenshots/column-reorder.gif
!screenshots/light-mode-toggle.gif
!screenshots/date-presets.gif
!screenshots/config.png
!screenshots/storage.png
!screenshots/admin.png

# Stray screenshots inside the app directory
cissp-cpe-tracker/*.png
cissp-cpe-tracker/*.jpg
